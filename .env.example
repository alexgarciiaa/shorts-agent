# Copy this file to ".env" and fill in what you need. ".env" is gitignored.

# --- Script generation ---
# Free Gemini key from https://aistudio.google.com/apikey (no credit card).
GEMINI_API_KEY=
# Optional fallback LLM (https://console.groq.com/keys)
GROQ_API_KEY=

# --- Publishing (leave blank until ready; nothing posts unless SHORTS_PLATFORMS is set) ---
# Comma list of targets to upload to, e.g. "youtube" or "youtube,tiktok". Empty = off.
SHORTS_PLATFORMS=

# YouTube (run: python scripts/get_youtube_token.py)
YT_CLIENT_ID=
YT_CLIENT_SECRET=
YT_REFRESH_TOKEN=

# TikTok (run: python scripts/get_tiktok_token.py) — requires an approved TikTok app
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REFRESH_TOKEN=
